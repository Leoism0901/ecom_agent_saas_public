# ============================================================
# 电商 SaaS 平台 —— 环境变量配置模板（可提交 Git，供团队参考）
# ============================================================
# 使用方式：复制本文件为 .env 并填入真实值
#   cp .env.example .env
# 所有敏感密钥在此文件中均已清空，请勿将真实值填入此处

# ============================================================
# 1. MySQL 数据库连接配置
# ============================================================
# 主机地址（容器映射到本地 localhost，生产环境可改为服务名）
MYSQL_HOST=localhost
# 端口（docker-compose 中映射为 3307 → 容器内 3306）
MYSQL_PORT=3307
# 数据库用户名
MYSQL_USER=root
# 数据库密码（敏感信息，生产环境务必更换）
MYSQL_PASSWORD=
# 目标数据库名（与 docker-compose 中 MYSQL_DATABASE 保持一致）
MYSQL_DATABASE=ecommerce_saas
# 字符集（utf8mb4 支持 emoji 与全 Unicode）
DB_CHARSET=utf8mb4

# ============================================================
# 2. MySQL 连接池参数
# ============================================================
# 是否打印 SQL 日志（开发环境 true，生产环境务必改为 false）
DB_ECHO=true
# 连接取出前是否 ping 探测保活
DB_POOL_PRE_PING=true
# 连接最大存活秒数（超过后自动回收，配合 MySQL wait_timeout）
DB_POOL_RECYCLE=3600
# 连接池常驻连接数
DB_POOL_SIZE=10
# 超过 pool_size 后最多额外创建的临时连接数
DB_MAX_OVERFLOW=20

# ============================================================
# 3. Redis 缓存连接配置（待接入）
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
REDIS_DEFAULT_TTL=300

# ============================================================
# 4. Qdrant 向量数据库连接配置（待接入）
# ============================================================
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# ============================================================
# 5. 大模型 / AI Agent 配置（待接入）
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_CONTEXT=128000
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# ============================================================
# 6. RAG 检索参数（待接入）
# ============================================================
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# ============================================================
# 7. Agent 运行参数（待接入）
# ============================================================
AGENT_MAX_TOOL_ROUNDS=10
AGENT_TOOL_TIMEOUT=30
AGENT_RATE_LIMIT_QPS=5

# ============================================================
# 8. JWT / 安全配置（待接入）
# ============================================================
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# ============================================================
# 9. CORS 跨域白名单（待接入）
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ============================================================
# 10. 限流器配置（滑动窗口 / Redis ZSET）
# ============================================================
# 滑动窗口大小（秒）
RATE_LIMIT_WINDOW_SECONDS=1
# 窗口内最大允许请求数（超过即触发 429 Too Many Requests）
RATE_LIMIT_MAX_REQUESTS=2
# ZSET Key 过期时间（秒），应大于窗口大小，防止限流标记常驻内存
RATE_LIMIT_KEY_TTL=5

# ============================================================
# 11. 日志与文件路径（待接入）
# ============================================================
LOG_LEVEL=INFO
LOG_DIR=./logs
UPLOAD_DIR=./uploads
TEMP_DIR=./tmp
